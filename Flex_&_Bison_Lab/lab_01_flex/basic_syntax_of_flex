#include <stdio.h>
%}


/* Section 2: Rules */
%%

{digit}+    { printf("Found an integer: %s\n", yytext); }
[a-z]+      { printf("Found a word: %s\n", yytext); }
.           { /* Ignore other characters */ }

%%




/* Section 3: User Subroutines (C code) */
int main() {
    print("lexer started...\n");
    yylex();
    return 0;
}


